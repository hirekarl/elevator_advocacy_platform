# Set default behavior to automatically guess encoding
* text=auto

# Enforce LF for all source files to prevent CRLF regressions
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Ensure lockfiles use LF
uv.lock text eol=lf
package-lock.json text eol=lf
